# Stellar network configuration
NEXT_PUBLIC_STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Application environment (development, staging, or production)
NEXT_PUBLIC_APP_ENV=development

# Optional server-only override for a custom/private Stellar network
STELLAR_NETWORK_PASSPHRASE=

# Server-only secret key for the account that signs and submits real
# `/api/wallet/send` payments (Issue #63). Must be a funded account's secret
# key (starts with S, 56 chars) on the configured network. NEVER commit a
# real value or expose this to the client — it is only read inside the
# `/api/wallet/send` route handler. Leave unset to have that route respond
# with ERR_PAYMENT_NOT_CONFIGURED instead of fabricating a result.
STELLAR_SOURCE_SECRET_KEY=

# Optional absolute URL for a separately hosted Globe Wallet API
NEXT_PUBLIC_API_BASE_URL=

# Optional CI-only merge analytics endpoint
MERGE_ANALYTICS_URL=

# ── Soroban contract configuration (optional for mock mode, required for live) ──
# Soroban RPC server URL (e.g. https://soroban-testnet.stellar.org)
SOROBAN_RPC_URL=
# Deployed GlobeWallet contract ID on the target network
SOROBAN_CONTRACT_ID_GLOBE_WALLET=
# Deployed TokenWrapper contract ID (pending upstream implementation)
SOROBAN_CONTRACT_ID_TOKEN_WRAPPER=
